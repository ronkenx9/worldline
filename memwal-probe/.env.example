# Get these from the Walrus Memory Playground: https://memory.walrus.xyz
# (wallet-gated — connect a Sui wallet, create an account, generate a delegate key)
MEMWAL_KEY=           # ed25519 delegate private key (hex)
MEMWAL_ACCOUNT=       # MemWalAccount object id on Sui
# Testnet relayer (default). Mainnet: https://relayer.memory.walrus.xyz
MEMWAL_RELAYER=https://relayer-staging.memory.walrus.xyz
